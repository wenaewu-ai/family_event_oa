# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# 只回應此群組的訊息（從群組 webhook 事件取得）
ALLOWED_GROUP_ID=Cxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Sheets
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/your_id/edit

# Google Service Account 憑證（二選一）
# 方法 A：直接貼上 JSON 內容（推薦用於 Cloud Run）
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# 方法 B：指定本地檔案路徑（適合本地開發）
# GOOGLE_CREDENTIALS_FILE=credentials.json
